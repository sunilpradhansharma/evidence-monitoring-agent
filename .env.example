# --- Required credentials (never commit real values; .env is gitignored) ---
# Copy this file to .env and paste your real keys after the '='. Leave no spaces or quotes.
# The startup preflight requires each ACTIVE target's key to be present AND non-empty, so an
# unfilled value here will (correctly) fail the preflight until you set it.
# ANTHROPIC_API_KEY is also the orchestrator + scorer key — required for every live run.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Conditional Open Evidence target (Provider-persona only) ---
# INACTIVE by default in config/targets.yaml — do NOT uncomment unless enterprise API access is
# confirmed AND the target is set active: true. While inactive, these are not required.
# OPENEVIDENCE_API_KEY=
# OPENEVIDENCE_ORG_ID=

# --- Model + orchestration (ids come only from config) ---
CLAUDE_MODEL_ID=claude-opus-4-6

# --- Storage + scheduling ---
EM_DB_PATH=./data/evidence.db
EM_SCHEDULE_CRON=0 2 * * *
EM_MAX_TOKENS_PER_RUN=2000000

# --- Targets config + outputs ---
EM_TARGETS_CONFIG=./src/evidence_monitor/config/targets.yaml
EM_OUTPUT_DIR=./out
EM_LOG_LEVEL=INFO
# Set to true to run adapters in deterministic offline/mock mode (no network)
EM_OFFLINE_MOCK=false

# --- Deterministic alert thresholds (tunable; code decides alerts) ---
EM_NEGATIVE_SENTIMENT_THRESHOLD=-0.3
EM_COMPETITOR_SENTIMENT_MARGIN=0.3
EM_RETRY_MAX_ATTEMPTS=3
